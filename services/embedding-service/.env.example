# Embedding Service env vars
EMBEDDING_SERVICE_PORT=3010

# Directory containing NYC Yellow Taxi parquet files (Jan-Mar 2025)
DATA_DIR=data/nyc_taxi

# Directory where the trained HIN + Word2Vec model are saved
MODEL_DIR=models

# PostgreSQL (used by hin_builder when pulling from DB as an alternative to parquet)
DATABASE_URL=postgresql://postgres:password@localhost:5432/lessgo_db
