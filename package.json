{
  "name": "lessgo-backend",
  "version": "1.0.0",
  "description": "LessGo Smart Carpooling Platform Backend - Microservices Architecture",
  "private": true,
  "workspaces": [
    "shared",
    "services/*"
  ],
  "scripts": {
    "clean:coverage": "rm -rf coverage",
    "migrate:create": "node-pg-migrate create -m shared/database/migrations",
    "migrate:up": "node-pg-migrate up -m shared/database/migrations --database-url-var DATABASE_URL --no-check-order",
    "migrate:down": "node-pg-migrate down -m shared/database/migrations --database-url-var DATABASE_URL",
    "migrate:status": "node-pg-migrate list -m shared/database/migrations --database-url-var DATABASE_URL",
    "seed": "node shared/database/seeds/seed.js",
    "bootstrap:db": "node scripts/bootstrap-db.mjs",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:coverage": "npm run clean:coverage && vitest run --config vitest.config.ts --coverage --coverage.reporter=text --coverage.reporter=lcov && npm run clean:coverage",
    "test:coverage:artifacts": "npm run clean:coverage && vitest run --config vitest.config.ts --coverage --coverage.reporter=text --coverage.reporter=lcov",
    "test:service-coverage": "node tests/check-service-coverage.mjs",
    "test:db": "node tests/check-supabase-postgres.mjs",
    "test:gateway:smoke": "bash tests/test-gateway-smoke.sh",
    "test:gateway:smoke:prod": "GATEWAY_URL=http://136.109.119.177 bash tests/test-gateway-smoke.sh",
    "test:ci": "npm run test:unit && npm run test:service-coverage",
    "test": "npm run test:unit",
    "dev:auth": "cd services/auth-service && npm run dev",
    "dev:user": "cd services/user-service && npm run dev",
    "dev:trip": "cd services/trip-service && npm run dev",
    "dev:booking": "cd services/booking-service && npm run dev",
    "dev:payment": "cd services/payment-service && npm run dev",
    "dev:notification": "cd services/notification-service && npm run dev",
    "dev:cost": "cd services/cost-calculation-service && npm run dev",
    "dev:gateway": "cd services/api-gateway && npm run dev",
    "dev:all": "concurrently --names \"Gateway,Auth,User,Trip,Booking,Payment,Notify,Cost\" --prefix-colors \"cyan,magenta,green,yellow,blue,red,gray,white\" \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:user\" \"npm run dev:trip\" \"npm run dev:booking\" \"npm run dev:payment\" \"npm run dev:notification\" \"npm run dev:cost\""
  },
  "keywords": [
    "carpooling",
    "ridesharing",
    "microservices",
    "postgresql",
    "postgis"
  ],
  "author": "LessGo Team",
  "license": "MIT",
  "dependencies": {
    "@faker-js/faker": "^8.3.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.3.1",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^7.4.4",
    "vitest": "^2.1.8"
  }
}
